generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model SiteContent {
  key              String   @id
  siteConfig       Json
  accessoryRecords Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AdminCredential {
  key          String   @id
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
